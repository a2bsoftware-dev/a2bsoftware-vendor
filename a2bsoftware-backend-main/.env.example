DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=a2b_dashboard
DB_USERNAME=root
DB_PASSWORD=root

# Get this from the "dashboard-tool" client's Credentials tab in the hosted
# Keycloak admin console (https://a2b-keycloak.onrender.com), realm
# "a2b-software" - never commit a real value here.
KEYCLOAK_CLIENT_SECRET=

FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081

# Optional - only needed to override the hosted Keycloak defaults baked into
# docker-compose.yml / application.yaml (e.g. pointing at a different realm).
# KEYCLOAK_CLIENT_ID=dashboard-tool
# KEYCLOAK_PUBLIC_URL=https://a2b-keycloak.onrender.com
# KEYCLOAK_INTERNAL_URL=https://a2b-keycloak.onrender.com
