// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Every UUID id/FK column in this database is physically BINARY(16), not the
// CHAR(36) text this file declares almost everywhere below - Hibernate on the
// Spring Boot side owns the actual DDL for UUIDs now and always writes/reads
// the compact binary form. Vendor.id, Project.id, ManageSupplier.*, and
// StartSurveyInformation.* are the only fields Prisma code still queries
// directly (the /supliers, /survey-start, /client-redirect-url routes), so
// only those were corrected to `Bytes @db.Binary(16)` - convert to/from
// dashed UUID strings at the JSON boundary via lib/uuid-binary.ts. The rest
// of the Char(36) declarations below are stale relative to the live schema
// but harmless, since no Prisma code path reads them.

model User {
  id             String    @id @default(uuid(7)) @db.Char(36)
  keycloak_id    String?   @unique @db.VarChar(255)
  user_name      String?   @db.VarChar(255)
  first_name     String?   @db.VarChar(255)
  last_name      String?   @db.VarChar(255)
  email          String    @unique @db.VarChar(255)
  password       String    @db.VarChar(255)
  check_password String?   @db.VarChar(255)
  role_id        String    @db.Char(36)
  wallet_balance Float     @default(0)
  parent_id      String?   @db.Char(36)
  code           String?   @db.VarChar(255)
  mobile         String?   @db.VarChar(255)
  created_at     DateTime? @default(now())
  updated_at     DateTime? @updatedAt

  @@map("users")
}

model Role {
  id     String  @id @default(uuid(7)) @db.Char(36)
  name   String  @db.VarChar(255)
  status Int     @default(1)

  @@map("roles")
}

model ClientUserPriv {
  id              String  @id @default(uuid(7)) @db.Char(36)
  user_type_id    String  @db.Char(36)
  access_right_id String  @db.Text

  @@map("client_user_priv")
}

model Project {
  id                  Bytes     @id @db.Binary(16)
  parent_project_id   String?   @db.Char(36)
  study_type          Int?
  surveyId            String?   @db.VarChar(255)
  project_name        String    @db.VarChar(255)
  req_complete        Int       @default(0)
  loi                 Int       @default(0)
  ir                  Int       @default(0)
  cpc                 Float     @default(0)
  vendor_cpi          Float     @default(0)
  survey_link         String?   @db.Text
  survey_test_link    String?   @db.Text
  country_id          String    @db.Char(36)
  language_id         String    @db.Char(36)
  currency_id         String    @db.Char(36)
  client_id           String    @db.Char(36)
  project_manager_id  String?   @db.Char(36)
  sales_manager_id    String?   @db.Char(36)
  status              Int       @default(1)
  device              String?   @db.VarChar(255)
  security_check_list String?   @db.VarChar(255)
  approved            Int       @default(0)
  top_survey          Int       @default(0)
  client_api_data     Int       @default(0)
  copy_for_client     Int       @default(0)
  notes               String?   @db.Text
  project_brief       String?   @db.Text
  created_at          DateTime? @default(now())
  updated_at          DateTime? @updatedAt

  @@map("projects")
}

model StartSurveyInformation {
  id                Bytes     @id @db.Binary(16)
  pid               Bytes?    @db.Binary(16)
  gid               Bytes?    @db.Binary(16)
  user_id           String    @db.VarChar(255)
  ref_id            String    @unique @db.VarChar(255)
  start_ip_address  String    @db.VarChar(45)
  end_ip_address    String?   @db.VarChar(45)
  status            Int       @default(0)
  email             String?   @db.VarChar(255)
  zip               String?   @db.VarChar(20)
  age               String?   @db.VarChar(10)
  gender            String?   @db.VarChar(10)
  start_time        DateTime?
  end_time          DateTime?
  browser           String?   @db.VarChar(255)
  date              DateTime? @db.Date

  @@map("start_survey_informations")
}

model Vendor {
  id               Bytes     @id @db.Binary(16)
  vendorName       String    @db.VarChar(255)
  apiToken         String?   @db.VarChar(255)
  contactPerson    String?   @db.VarChar(255)
  contact          String?   @db.VarChar(255)
  email            String?   @db.VarChar(255)
  paymentTerms     String?   @db.VarChar(255)
  completeLink     String?   @db.Text
  disqualifyLink   String?   @db.Text
  qoutafullLink    String?   @db.Text
  securityTermlink String?   @db.Text
  internal_panel   Int       @default(0)

  @@map("vendors")
}

model Client {
  id            String  @id @default(uuid(7)) @db.Char(36)
  clientName    String  @db.VarChar(255)
  contactPerson String? @db.VarChar(255)
  contact       String? @db.VarChar(255)
  email         String? @db.VarChar(255)
  paymentTerms  String? @db.VarChar(255)

  @@map("clients")
}

model Country {
  id        String  @id @default(uuid(7)) @db.Char(36)
  name      String  @db.VarChar(255)
  // External panel/client country code (e.g. Zamplia's own numbering) - a plain lookup
  // value, not a foreign key to another table's UUID primary key.
  countryID Int?

  @@map("countries")
}

model ManageSupplier {
  id                Bytes   @id @db.Binary(16)
  project_id        Bytes   @db.Binary(16)
  vendor_id         Bytes   @db.Binary(16)
  data_redirect     String? @db.VarChar(255)
  completeLink      String? @db.Text
  disqualifyLink    String? @db.Text
  qoutafullLink     String? @db.Text
  securityTermlink  String? @db.Text
  cost_per_complete Float   @default(0)
  complete_request  Int     @default(0)
  max_redirect      Int     @default(0)
  notes             String? @db.Text
  status            Int     @default(1)
  internal_splier   Int     @default(0)

  @@map("manage_suppliers")
}

model Language {
  id            String @id @default(uuid(7)) @db.Char(36)
  language_name String @db.VarChar(255)

  @@map("languages")
}

model Currency {
  id            String @id @default(uuid(7)) @db.Char(36)
  currency_name String @db.VarChar(255)

  @@map("currencies")
}

// The models below are never queried from Prisma/Next.js code anymore - they're owned
// entirely by the Spring Boot backend's `qualifications`, `clientapidata`, and `settings`
// packages. They stay here only because Prisma (`db-init`/`prisma db push`) is the sole thing
// in this stack that creates tables at all (Hibernate runs with ddl-auto: none); removing a
// model here drops its table on the next push, not just stops Prisma code from touching it.
// Same reasoning as every other already-migrated table (Project, User, Client, ...) that Prisma
// still owns the DDL for even though only Spring Boot's JPA layer reads/writes them now.

model Setting {
  id    String @id @default(uuid(7)) @db.Char(36)
  param String @unique @db.VarChar(255)
  value String @db.Text

  @@map("settings")
}

model Question {
  id            String  @id @default(uuid(7)) @db.Char(36)
  questionId    String  @db.VarChar(255)
  project_id    String  @db.Char(36)
  countryId     String  @db.Char(36)
  question_name String  @db.Text
  type          Int

  @@map("questions")
}

model Option {
  id          String  @id @default(uuid(7)) @db.Char(36)
  question_id String  @db.Char(36)
  answerId    String  @db.VarChar(100)
  answerTitle String  @db.VarChar(255)
  answer      Int

  @@map("options")
}

model ApplyQualification {
  id         String  @id @default(uuid(7)) @db.Char(36)
  project_id String  @db.Char(36)
  question_id String @db.Char(36)
  option_id  String? @db.Char(36)

  @@map("apply_qualifications")
}

model ApiSetting {
  id        String @id @default(uuid(7)) @db.Char(36)
  api_name  String @db.VarChar(255)
  client_id String @db.Char(36)

  @@map("api_settings")
}
