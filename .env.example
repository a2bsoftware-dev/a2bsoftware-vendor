ZAMP_KEY=""
EXIT_HMAC_KEY=""
# Browser-facing Spring Boot API base URL - baked into the client bundle at
# build time, must be reachable from the user's browser (see Dockerfile).
NEXT_PUBLIC_API_BASE_URL="http://localhost:8081"
# Backend URL used server-side by next.config.ts's rewrites() for the
# legacy (non-migrated) route proxies - also baked in at build time.
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"
# Server-side only, read at runtime (not baked in): destination for the
# /api/:path* rewrite that proxies every browser API call through this app's
# own origin. Defaults to NEXT_PUBLIC_API_BASE_URL, which is correct for
# plain `npm run dev`; docker-compose.yml overrides this to
# host.docker.internal since `localhost` from inside a container means the
# container itself, not the backend's host-published port.
API_INTERNAL_URL="http://localhost:8081"